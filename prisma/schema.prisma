// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  name     String?
  email    String    @unique
  password String
  role     UserRole?

  managedStudents Student[] @relation("StudentPrimaryTeacher")

  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model Student {
  id             String    @id @default(uuid())
  fullName       String
  dateOfBirth    DateTime?
  gender         String?
  addressLine    String?
  postalCode     String?
  city           String?
  phoneNumber    String?
  email          String?   @unique
  password       String?
  familyDetails  String?
  custodyDetails String?

  groep       String?
  bloomNiveau Int     @default(1)

  primaryTeacherId String?
  primaryTeacher   User?   @relation("StudentPrimaryTeacher", fields: [primaryTeacherId], references: [id], onDelete: SetNull)

  profile     StudentProfile?
  assignments Assignment[]
  oppChunks   OppChunk[]
  chatSession StudentChatSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// This is a join table to represent the many-to-many relationship between teachers and students
model TeacherStudent {
  id        String @id @default(uuid())
  teacherId String
  studentId String

  assignedAt DateTime @default(now())

  @@unique([teacherId, studentId])
}

model StudentProfile {
  id          String  @id @default(uuid())
  studentId   String  @unique
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdById String?

  registrationNumber     String?
  currentDate            DateTime?
  currentSchoolYearGroup String?
  currentTeacher         String?

  schoolOfOrigin String?
  schoolHistory  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Subject {
  id          String  @id @default(uuid())
  name        String
  description String?

  assignments Assignment[]

  createdAt DateTime @default(now())
}

model Assignment {
  id          String           @id @default(uuid())
  title       String
  description String?
  status      AssignmentStatus @default(PENDING)
  dueDate     DateTime?
  bloomLevel  String?
  bloomNiveau Int              @default(1)
  uitleg      String?
  studentTip  String?
  studentWork String?
  savedAt     DateTime?
  submittedAt DateTime?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  teacherFeedback TeacherFeedback?
  reflection      Reflection?
  submissions     AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeacherFeedback {
  id           String     @id @default(uuid())
  assignmentId String     @unique
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime   @default(now())
}

model Reflection {
  id           String     @id @default(uuid())
  assignmentId String     @unique
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime   @default(now())
}

model AssignmentSubmission {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  mimeType     String
  fileSize     Int
  uploadedAt   DateTime   @default(now())
}

model OppChunk {
  id        Int                          @id @default(autoincrement())
  studentId String
  student   Student                      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tekst     String
  embedding Unsupported("vector(1024)")?
}

model StudentChatSession {
  id        String               @id @default(uuid())
  studentId String               @unique
  student   Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messages  StudentChatMessage[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model StudentChatMessage {
  id         String           @id @default(uuid())
  sessionId  String
  session    StudentChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       StudentChatRole
  content    String
  createdAt  DateTime         @default(now())

  @@index([sessionId, createdAt])
}

enum UserRole {
  TEACHER
  ADMIN
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum StudentChatRole {
  USER
  ASSISTANT
}
